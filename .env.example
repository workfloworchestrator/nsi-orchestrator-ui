ENVIRONMENT_NAME=Development
ORCHESTRATOR_API_HOST=http://localhost:8080
ORCHESTRATOR_API_PATH=/api
ORCHESTRATOR_GRAPHQL_HOST=http://localhost:8080
ORCHESTRATOR_GRAPHQL_PATH=/api/graphql
ORCHESTRATOR_WEBSOCKET_URL=ws://localhost:8080/api/ws/events
USE_WEB_SOCKETS=false
USE_THEME_TOGGLE=false
SHOW_WORKFLOW_INFORMATION_LINK=true
WORKFLOW_INFORMATION_LINK_URL="https://workfloworchestrator.org/"
ENABLE_SUPPORT_MENU_ITEM=true
SUPPORT_MENU_ITEM_URL="https://workfloworchestrator.org/orchestrator-core/reference-docs/tldr/"
ENABLE_AO_STACK_STATUS=true
AO_STACK_STATUS_URL=https://status.orchestration.surf/status/prd
START_WORKFLOW_FILTERS="active|pre_production|phase_out"

# Disable cache - usefull when in development
NEXT_PUBLIC_DISABLE_CACHE=false

# Override the sidebar logo with a deployment-specific image (e.g. an ANA logo). Leave empty to
# show the built-in Workflow Orchestrator wordmark.
APP_LOGO_URL=

# Auth variables. Any OIDC provider; request whatever scope makes group membership available.
OAUTH2_ACTIVE=true
NEXTAUTH_PROVIDER_ID="oidc"
NEXTAUTH_PROVIDER_NAME="OIDC"
NEXTAUTH_AUTHORIZATION_SCOPE_OVERRIDE="openid profile email groups"
OAUTH2_CLIENT_ID="nsi-orchestrator-ui"
OAUTH2_CLIENT_SECRET=""
OIDC_CONF_FULL_WELL_KNOWN_URL="https://your-oidc-provider.example/.well-known/openid-configuration"

# UX-only sign-in guard: reject users whose groups claim lacks this group. Leave empty to allow any
# authenticated user (the backend still enforces the operators group). Set both in a deployment,
# e.g. NEXTAUTH_GROUPS_CLAIM=eduperson_entitlement for SRAM.
NEXTAUTH_REQUIRED_GROUP=
NEXTAUTH_GROUPS_CLAIM="groups"

# Required by the Nextauth middleware
NEXTAUTH_URL=http://localhost:3001/api/auth
NEXTAUTH_SECRET="NEXTAUTH_SECRET"

